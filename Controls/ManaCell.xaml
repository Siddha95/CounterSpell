<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Controls.ManaCell"
             x:Name="root">

    <Border BackgroundColor="#1E1E38"
            StrokeShape="RoundRectangle 14"
            Stroke="#3D2B6E"
            StrokeThickness="1"
            Padding="8,10">
        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">

            <!-- Icona mana: immagine se disponibile, cerchio lettera come fallback -->
            <Grid WidthRequest="50" HeightRequest="50" HorizontalOptions="Center">

                <!-- Fallback: cerchio colorato con lettera (solo per C - colorless) -->
                <Border IsVisible="{Binding HasNoIcon, Source={x:Reference root}}"
                        WidthRequest="50"
                        HeightRequest="50"
                        BackgroundColor="{Binding CircleColor, Source={x:Reference root}}"
                        StrokeShape="Ellipse"
                        Stroke="#00000040"
                        StrokeThickness="2">
                    <Label Text="{Binding ManaName, Source={x:Reference root}}"
                           TextColor="White"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>

                <!-- Icona personalizzata -->
                <Image IsVisible="{Binding HasIcon, Source={x:Reference root}}"
                       Source="{Binding IconSource, Source={x:Reference root}}"
                       WidthRequest="50"
                       HeightRequest="50"
                       Aspect="AspectFit" />
            </Grid>

            <!-- Contatore -->
            <Label Text="{Binding Count, Source={x:Reference root}}"
                   TextColor="#E8E8F0"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Tasti +/- -->
            <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                <Button Text="−"
                        Command="{Binding DecrementCommand, Source={x:Reference root}}"
                        CommandParameter="{Binding ManaName, Source={x:Reference root}}"
                        WidthRequest="38"
                        HeightRequest="38"
                        FontSize="20"
                        CornerRadius="10"
                        BackgroundColor="#374151"
                        TextColor="#E8E8F0"
                        Padding="0" />
                <Button Text="+"
                        Command="{Binding IncrementCommand, Source={x:Reference root}}"
                        CommandParameter="{Binding ManaName, Source={x:Reference root}}"
                        WidthRequest="38"
                        HeightRequest="38"
                        FontSize="20"
                        CornerRadius="10"
                        BackgroundColor="#7C3AED"
                        TextColor="White"
                        Padding="0" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Border>

</ContentView>

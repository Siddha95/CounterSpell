<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Controls.ManaCell"
             x:Name="root">

    <Border BackgroundColor="#1E1E38"
            StrokeShape="RoundRectangle 12"
            Stroke="#3D2B6E"
            StrokeThickness="1"
            Padding="4,6">
        <VerticalStackLayout Spacing="3"
                             HorizontalOptions="Fill">

            <!-- Icona mana (immagine) o cerchio lettera (fallback) -->
            <Grid WidthRequest="34"
                  HeightRequest="34"
                  HorizontalOptions="Center">

                <Border IsVisible="{Binding HasNoIcon, Source={x:Reference root}}"
                        WidthRequest="34"
                        HeightRequest="34"
                        BackgroundColor="{Binding CircleColor, Source={x:Reference root}}"
                        StrokeShape="Ellipse"
                        Stroke="#00000040"
                        StrokeThickness="2">
                    <Label Text="{Binding ManaName, Source={x:Reference root}}"
                           TextColor="White"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>

                <Image IsVisible="{Binding HasIcon, Source={x:Reference root}}"
                       Source="{Binding IconSource, Source={x:Reference root}}"
                       WidthRequest="34"
                       HeightRequest="34"
                       Aspect="AspectFit" />
            </Grid>

            <!-- Contatore -->
            <Label Text="{Binding Count, Source={x:Reference root}}"
                   TextColor="#E8E8F0"
                   FontSize="15"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Tasti +/- a larghezza piena -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                <Button Grid.Column="0"
                        Text="−"
                        Command="{Binding DecrementCommand, Source={x:Reference root}}"
                        CommandParameter="{Binding ManaName, Source={x:Reference root}}"
                        HeightRequest="32"
                        FontSize="16"
                        CornerRadius="8"
                        BackgroundColor="#374151"
                        TextColor="#E8E8F0"
                        Padding="0" />
                <Button Grid.Column="1"
                        Text="+"
                        Command="{Binding IncrementCommand, Source={x:Reference root}}"
                        CommandParameter="{Binding ManaName, Source={x:Reference root}}"
                        HeightRequest="32"
                        FontSize="16"
                        CornerRadius="8"
                        BackgroundColor="#7C3AED"
                        TextColor="White"
                        Padding="0" />
            </Grid>

        </VerticalStackLayout>
    </Border>

</ContentView>

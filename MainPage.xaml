<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiApp1.Controls"
             xmlns:behaviors="clr-namespace:MauiApp1.Behaviors"
             xmlns:vm="clr-namespace:MauiApp1.ViewModels"
             x:Class="MauiApp1.MainPage"
             BackgroundColor="#121212"
             Title="">

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <!--
        Root Grid — budget verticale calibrato per 360×640 dp (telefono piccolo):
          Row 0 (*):    Vita     ~250 dp — prende tutto lo spazio residuo
          Row 1 (Auto): Mana     ~210 dp — celle compatte
          Row 2 (Auto): Storm     ~80 dp
          Row 3 (Auto): Footer    ~46 dp
        Padding + spacing: ~44 dp
        Totale fisso: ~380 dp  →  vita su 640 dp = ~260 dp
    -->
    <Grid RowDefinitions="*,Auto,Auto,Auto"
          ColumnDefinitions="*"
          RowSpacing="8"
          Padding="10">

        <!-- ══════════════════════════════════════
             SEZIONE VITA  (YOU | OPPONENT)
             ══════════════════════════════════════ -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,*"
              ColumnSpacing="8">

            <!-- ── YOU (viola) ── -->
            <Border Grid.Column="0"
                    BackgroundColor="#1A1535"
                    StrokeShape="RoundRectangle 18"
                    Stroke="#5B21B6"
                    StrokeThickness="1"
                    Padding="10,12">
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">

                    <Label Text="YOU"
                           TextColor="#7C3AED"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="2"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding LifeTotal}"
                           TextColor="#DDD6FE"
                           FontSize="72"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                        <Button Grid.Column="0"
                                Text="−"
                                Command="{Binding DecrementLifeCommand}"
                                HeightRequest="48"
                                FontSize="26"
                                CornerRadius="12"
                                BackgroundColor="#3B0764"
                                TextColor="#DDD6FE"
                                Padding="0">
                            <Button.Behaviors>
                                <behaviors:RepeatClickBehavior />
                            </Button.Behaviors>
                        </Button>
                        <Button Grid.Column="1"
                                Text="+"
                                Command="{Binding IncrementLifeCommand}"
                                HeightRequest="48"
                                FontSize="26"
                                CornerRadius="12"
                                BackgroundColor="#7C3AED"
                                TextColor="White"
                                Padding="0">
                            <Button.Behaviors>
                                <behaviors:RepeatClickBehavior />
                            </Button.Behaviors>
                        </Button>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── OPPONENT (magenta) ── -->
            <Border Grid.Column="1"
                    BackgroundColor="#1E0B1E"
                    StrokeShape="RoundRectangle 18"
                    Stroke="#7C3AED"
                    StrokeThickness="1"
                    Padding="10,12">
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">

                    <Label Text="OPPONENT"
                           TextColor="#C62828"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="2"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding OpponentLifeTotal}"
                           TextColor="#DDD6FE"
                           FontSize="72"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                        <Button Grid.Column="0"
                                Text="−"
                                Command="{Binding DecrementOpponentLifeCommand}"
                                HeightRequest="48"
                                FontSize="26"
                                CornerRadius="12"
                                BackgroundColor="#3B0A40"
                                TextColor="#F0ABFC"
                                Padding="0">
                            <Button.Behaviors>
                                <behaviors:RepeatClickBehavior />
                            </Button.Behaviors>
                        </Button>
                        <Button Grid.Column="1"
                                Text="+"
                                Command="{Binding IncrementOpponentLifeCommand}"
                                HeightRequest="48"
                                FontSize="26"
                                CornerRadius="12"
                                BackgroundColor="#A21CAF"
                                TextColor="White"
                                Padding="0">
                            <Button.Behaviors>
                                <behaviors:RepeatClickBehavior />
                            </Button.Behaviors>
                        </Button>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════
             SEZIONE MANA
             ══════════════════════════════════════ -->
        <Border Grid.Row="1"
                BackgroundColor="#1A1A2E"
                StrokeShape="RoundRectangle 18"
                Stroke="#3D2B6E"
                StrokeThickness="1"
                Padding="10,8">
            <VerticalStackLayout Spacing="6">

                <Label Text="MANA POOL"
                       TextColor="#7060A8"
                       FontSize="10"
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       HorizontalOptions="Center" />

                <Grid ColumnDefinitions="*,*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="6"
                      RowSpacing="6">

                    <!-- Riga 0: W · U · B -->
                    <controls:ManaCell Grid.Row="0" Grid.Column="0"
                                       ManaName="W" CircleColor="#B8A030"
                                       IconSource="white_mana.webp"
                                       Count="{Binding ManaW}"
                                       IncrementCommand="{Binding IncrementManaCommand}"
                                       DecrementCommand="{Binding DecrementManaCommand}" />

                    <controls:ManaCell Grid.Row="0" Grid.Column="1"
                                       ManaName="U" CircleColor="#1565C0"
                                       IconSource="blu_mana.webp"
                                       Count="{Binding ManaU}"
                                       IncrementCommand="{Binding IncrementManaCommand}"
                                       DecrementCommand="{Binding DecrementManaCommand}" />

                    <controls:ManaCell Grid.Row="0" Grid.Column="2"
                                       ManaName="B" CircleColor="#6A1B9A"
                                       IconSource="black_mana.webp"
                                       Count="{Binding ManaB}"
                                       IncrementCommand="{Binding IncrementManaCommand}"
                                       DecrementCommand="{Binding DecrementManaCommand}" />

                    <!-- Riga 1: R · G · C -->
                    <controls:ManaCell Grid.Row="1" Grid.Column="0"
                                       ManaName="R" CircleColor="#C62828"
                                       IconSource="red_mana.webp"
                                       Count="{Binding ManaR}"
                                       IncrementCommand="{Binding IncrementManaCommand}"
                                       DecrementCommand="{Binding DecrementManaCommand}" />

                    <controls:ManaCell Grid.Row="1" Grid.Column="1"
                                       ManaName="G" CircleColor="#2E7D32"
                                       IconSource="green_mana.webp"
                                       Count="{Binding ManaG}"
                                       IncrementCommand="{Binding IncrementManaCommand}"
                                       DecrementCommand="{Binding DecrementManaCommand}" />

                    <controls:ManaCell Grid.Row="1" Grid.Column="2"
                                       ManaName="C" CircleColor="#546E7A"
                                       IconSource="colorless_mana.webp"
                                       Count="{Binding ManaC}"
                                       IncrementCommand="{Binding IncrementManaCommand}"
                                       DecrementCommand="{Binding DecrementManaCommand}" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ══════════════════════════════════════
             SEZIONE STORM
             ══════════════════════════════════════ -->
        <Border Grid.Row="2"
                BackgroundColor="#1A1A2E"
                StrokeShape="RoundRectangle 18"
                Stroke="#3D2B6E"
                StrokeThickness="1"
                Padding="10,8">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">

                <Button Grid.Column="0"
                        Text="− Spell"
                        Command="{Binding RemoveSpellCommand}"
                        CornerRadius="12"
                        BackgroundColor="#374151"
                        TextColor="#E8E8F0"
                        FontAttributes="Bold"
                        FontSize="13"
                        Padding="12,8"
                        VerticalOptions="Center" />

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Image Source="storm_count.webp"
                               WidthRequest="12"
                               HeightRequest="12"
                               VerticalOptions="Center"
                               Aspect="AspectFit" />
                        <Label Text="STORM"
                               TextColor="#7060A8"
                               FontSize="10"
                               FontAttributes="Bold"
                               CharacterSpacing="2"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding StormCount}"
                           TextColor="#F59E0B"
                           FontSize="40"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Button Grid.Column="2"
                        Text="+ Spell"
                        Command="{Binding AddSpellCommand}"
                        CornerRadius="12"
                        BackgroundColor="#B45309"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="13"
                        Padding="12,8"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             FOOTER
             ══════════════════════════════════════ -->
        <Grid Grid.Row="3"
              ColumnDefinitions="*,*"
              ColumnSpacing="8">

            <Button Grid.Column="0"
                    Text="Reset Turn"
                    Command="{Binding ResetTurnCommand}"
                    CornerRadius="12"
                    BackgroundColor="#374151"
                    TextColor="#E8E8F0"
                    FontAttributes="Bold"
                    FontSize="13"
                    HeightRequest="46" />

            <Button Grid.Column="1"
                    Text="Reset Game"
                    Command="{Binding ResetGameCommand}"
                    CornerRadius="12"
                    BackgroundColor="#991B1B"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="13"
                    HeightRequest="46" />
        </Grid>

    </Grid>

</ContentPage>
